// ============================================================
// G-CONCURSOS — Prisma Schema
// PostgreSQL · Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────
model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  password_hash       String?  // null = primeiro acesso ainda não definiu senha
  full_name           String
  role                String   @default("user")         // "user" | "admin"

  // ── Assinatura — WooCommerce Subscriptions ───────────────
  subscription_type   String?  // "Aluno Clube do Pedrão" | "Aluno Clube dos Cascas" | "Professor"
  subscription_status String   @default("inactive")
  // Valores: active | pending-cancel | on-hold | cancelled | expired | pending | inactive
  subscription_active Boolean  @default(false)
  // Cache booleano: true = status em ACTIVE_STATUSES. Atualizado por syncUserSubscriptionCache.

  // ── Membership — WooCommerce Memberships ─────────────────
  membership_status     String?   // active | paused | cancelled | expired | delayed | complimentary | pending | free_trial
  membership_active     Boolean   @default(false)
  // true quando membership_status === "active"
  membership_expires_at DateTime? // Data de expiração da associação (null = sem prazo)
  membership_plan       String?   // Nome do plano (ex.: "Clube dos Cascas")

  first_login         Boolean  @default(true)  // true = precisa definir senha
  study_streak        Int      @default(0)
  last_study_date     String?  // ISO date string

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // ── Relações ─────────────────────────────────────────────
  questions          Question[]
  attempts           Attempt[]
  notebooks          Notebook[]
  comments           Comment[]
  subscriptions      Subscription[]
  reports_sent       QuestionReport[] @relation("ReportedBy")
  reports_resolved   QuestionReport[] @relation("ResolvedBy")
  flashcards_created Flashcard[]
  flashcard_reviews  FlashcardReview[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTION  ←  Fonte da verdade para controle de acesso
// ─────────────────────────────────────────────────────────────
model Subscription {
  id      String @id @default(uuid())
  user_id String

  // ── Status e tipo ─────────────────────────────────────────
  status            String  @default("inactive")
  // Valores: active | pending-cancel | on-hold | cancelled | expired | pending | inactive
  subscription_type String?
  // "Aluno Clube do Pedrão" | "Aluno Clube dos Cascas"

  // ── IDs externos WooCommerce ──────────────────────────────
  woo_subscription_id String? @unique  // ID da subscription no WooCommerce Subscriptions
  woo_order_id        String?          // ID do pedido de origem (order webhook fallback)

  // ── Datas de controle ─────────────────────────────────────
  started_at      DateTime? // Quando a assinatura começou
  expires_at      DateTime? // Data de término/expiração (null = sem prazo)
  next_payment_at DateTime? // Próxima cobrança
  cancelled_at    DateTime? // Data do cancelamento

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // ── Relações ─────────────────────────────────────────────
  user    User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  history SubscriptionHistory[]

  @@index([user_id])
  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTION HISTORY  ←  Auditoria de mudanças de status
// ─────────────────────────────────────────────────────────────
model SubscriptionHistory {
  id              String  @id @default(uuid())
  subscription_id String

  previous_status String? // null quando criada pela primeira vez
  new_status      String
  reason          String? // "webhook" | "created" | "order.completed" | "manual"
  woo_event       String? // Header X-WC-Webhook-Topic ("subscription.updated", etc.)
  payload_id      String? // ID do objeto WooCommerce para rastreabilidade

  created_at DateTime @default(now())

  // ── Relação ───────────────────────────────────────────────
  subscription Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@map("subscription_history")
}

// ─────────────────────────────────────────────────────────────
// QUESTION
// ─────────────────────────────────────────────────────────────
model Question {
  id             String   @id @default(uuid())
  code           String?  @unique
  text           String
  discipline     String
  difficulty     String   // "Fácil" | "Médio" | "Difícil"
  exam_board     String?
  year           Int?
  position       String?
  option_a       String
  option_b       String
  option_c       String?  // null para questões "Certo ou Errado"
  option_d       String?  // null para questões "Certo ou Errado"
  option_e       String?  // null para questões "Certo ou Errado"
  correct_answer String   // "A" | "B" | "C" | "D" | "E"
  explanation    String
  question_type  String?
  subjects       String[] // Array de assuntos
  created_by     String?
  created_date   DateTime @default(now())
  updated_at     DateTime @updatedAt

  creator  User?              @relation(fields: [created_by], references: [email], onDelete: SetNull)
  attempts  Attempt[]
  notebooks NotebookQuestion[]
  comments  Comment[]
  reports   QuestionReport[]

  @@map("questions")
}

// ─────────────────────────────────────────────────────────────
// ATTEMPT
// ─────────────────────────────────────────────────────────────
model Attempt {
  id            String   @id @default(uuid())
  question_id   String
  user_id       String
  chosen_answer String
  is_correct    Boolean
  answered_at   DateTime
  created_date  DateTime @default(now())
  created_by    String?  // email (compatibilidade retroativa)

  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("attempts")
}

// ─────────────────────────────────────────────────────────────
// NOTEBOOK
// ─────────────────────────────────────────────────────────────
model Notebook {
  id           String   @id @default(uuid())
  name         String
  description  String?
  color        String   @default("blue")
  created_by   String
  created_date DateTime @default(now())
  updated_at   DateTime @updatedAt

  creator   User               @relation(fields: [created_by], references: [email], onDelete: Cascade)
  questions NotebookQuestion[]

  @@map("notebooks")
}

model NotebookQuestion {
  notebook_id String
  question_id String
  added_at    DateTime @default(now())

  notebook Notebook @relation(fields: [notebook_id], references: [id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@id([notebook_id, question_id])
  @@map("notebook_questions")
}

// ─────────────────────────────────────────────────────────────
// QUESTION REPORT  ←  Alunos reportam questões possivelmente erradas
// ─────────────────────────────────────────────────────────────
model QuestionReport {
  id          String    @id @default(uuid())
  question_id String
  user_id     String
  reason      String    // Explicação do aluno sobre o problema
  status      String    @default("pending")
  // Valores: pending | reviewing | resolved | dismissed

  admin_note  String?   // Observação do admin/professor ao resolver
  resolved_by String?   // ID do admin/professor que resolveu
  resolved_at DateTime? // Data da resolução

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  question    Question  @relation(fields: [question_id], references: [id], onDelete: Cascade)
  reporter    User      @relation("ReportedBy",  fields: [user_id],      references: [id], onDelete: Cascade)
  resolver    User?     @relation("ResolvedBy",  fields: [resolved_by],  references: [id], onDelete: SetNull)

  @@index([question_id])
  @@index([status])
  @@map("question_reports")
}

// ─────────────────────────────────────────────────────────────
// COMMENT
// ─────────────────────────────────────────────────────────────
model Comment {
  id           String   @id @default(uuid())
  question_id  String
  user_id      String?
  text         String
  author_name  String
  author_role  String
  created_date DateTime @default(now())

  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("comments")
}

// ─────────────────────────────────────────────────────────────
// FLASHCARD  ←  Cards criados por usuários ou globais (admin)
// ─────────────────────────────────────────────────────────────
model Flashcard {
  id         String   @id @default(uuid())
  front      String
  back       String
  discipline String
  subjects   String[] // Array de assuntos
  is_global  Boolean  @default(false) // true = criado pelo admin, visível para todos
  created_by String?  // user_id do criador (null = seed/admin sem registro)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator User?             @relation(fields: [created_by], references: [id], onDelete: SetNull)
  reviews FlashcardReview[]

  @@index([discipline])
  @@index([is_global])
  @@map("flashcards")
}

// ─────────────────────────────────────────────────────────────
// FLASHCARD REVIEW  ←  Dados de revisão espaçada (SM-2 Anki)
// ─────────────────────────────────────────────────────────────
model FlashcardReview {
  id           String   @id @default(uuid())
  flashcard_id String
  user_id      String

  // SM-2 fields
  quality     Int   // 0-5: 0=Errei, 3=Difícil, 4=Bom, 5=Fácil
  ease_factor Float @default(2.5) // Fator de facilidade (mín 1.3)
  interval    Int   @default(1)   // Intervalo em dias até próxima revisão
  repetitions Int   @default(0)   // Número de repetições bem-sucedidas consecutivas

  due_date    DateTime @default(now()) // Data da próxima revisão
  reviewed_at DateTime @default(now()) // Data da última revisão

  flashcard Flashcard @relation(fields: [flashcard_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([flashcard_id, user_id])
  @@index([user_id, due_date])
  @@map("flashcard_reviews")
}
